server:
  port: 8098
  error:
    include-message: always

spring:
  application:
    name: product-service

  profiles:
    active: dev

  config:
    import: optional:configserver:http://localhost:8877

management:
  tracing:
    sampling:
      probability: 1.0   # trace 100% requests
  zipkin:
    tracing:
      endpoint: http://localhost:9411/api/v2/spans
  endpoints:
    web:
      exposure:
        include: "*"